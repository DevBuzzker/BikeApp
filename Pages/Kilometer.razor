@page "/kilometer"
@inject BikeStateService State

<PageTitle>Kilometer – E-Bike Tracker</PageTitle>

<Toast @ref="_toast" />

@* ── Stats ────────────────────────────────────────────────────────────── *@
<div class="section-label">Gesamtkilometer</div>
<div class="km-card">
    <div class="km-total">@State.TotalKm.ToString("F1")</div>
    <div class="km-sub">Kilometer gesamt</div>
    <div class="km-grid">
        <div class="km-mini">
            <span class="km-mini-label">Diese Woche</span>
            <span class="km-mini-val" style="color:var(--accent)">@State.WeekKm.ToString("F1") km</span>
        </div>
        <div class="km-mini">
            <span class="km-mini-label">Diesen Monat</span>
            <span class="km-mini-val" style="color:var(--accent2)">@State.MonthKm.ToString("F1") km</span>
        </div>
        <div class="km-mini">
            <span class="km-mini-label">Fahrten</span>
            <span class="km-mini-val">@State.Trips.Count</span>
        </div>
        <div class="km-mini">
            <span class="km-mini-label">Ø pro Fahrt</span>
            <span class="km-mini-val" style="color:var(--warn)">@State.AvgKm.ToString("F1") km</span>
        </div>
    </div>
</div>

@* ── Fahrt hinzufügen ─────────────────────────────────────────────────── *@
<div class="section-label">Fahrt hinzufügen</div>
<div class="form-card">
    <div class="input-row">
        <span class="input-label">Strecke (km)</span>
        <div class="input-wrap">
            <input type="number" min="0" step="0.1" @bind="_km"
                   class="@(_kmError ? "error" : "")"
                   placeholder="z.B. 18.5" />
            <span class="input-suffix">km</span>
        </div>
        @if (_kmError)
        {
            <div class="error-msg visible">Bitte eine gültige Kilometer-Zahl eingeben.</div>
        }
    </div>

    <div class="input-row">
        <span class="input-label">Name / Beschreibung (optional)</span>
        <input type="text" @bind="_name" placeholder="z.B. Arbeit, Einkaufen..." />
        <div class="quick-tags">
            @foreach (var tag in _quickTags)
            {
                <button class="quick-tag" type="button" @onclick="() => _name = tag">@tag</button>
            }
        </div>
    </div>

    <div class="input-row">
        <span class="input-label">Datum & Uhrzeit</span>
        <div class="input-wrap-split">
            <input type="date" lang="de-DE" @bind="_date" style="flex:2" />
            <input type="time" @bind="_time" style="flex:1" />
        </div>
    </div>

    <div class="input-row">
        <span class="input-label">Akku verbraucht (optional)</span>
        <div class="input-wrap">
            <input type="number" min="0" max="100" @bind="_battUsed" placeholder="z.B. 30" />
            <span class="input-suffix">%</span>
        </div>
    </div>

    <div class="btn-row">
        <button class="btn secondary" @onclick="ClearAll">Liste leeren</button>
        <button class="btn" @onclick="AddTrip">Fahrt hinzufügen ✓</button>
    </div>
</div>

@* ── Delete confirmation ──────────────────────────────────────────────── *@
@if (_confirmDeleteId.HasValue)
{
    <div class="confirm-overlay" @onclick="CancelDelete">
        <div class="confirm-box" @onclick:stopPropagation>
            <div class="confirm-text">Fahrt wirklich löschen?</div>
            <div class="btn-row">
                <button class="btn secondary" @onclick="CancelDelete">Abbrechen</button>
                <button class="btn btn-danger" @onclick="ConfirmDeleteYes">Löschen</button>
            </div>
        </div>
    </div>
}

@* ── Fahrtprotokoll ───────────────────────────────────────────────────── *@
<div class="section-label">Fahrtprotokoll</div>

@if (!State.Trips.Any())
{
    <div class="no-trips">Noch keine Fahrten eingetragen.</div>
}
else
{
    @foreach (var trip in State.Trips)
    {
        <div class="trip-item @(_editId == trip.Id ? "trip-editing" : "")">
            @if (_editId == trip.Id)
            {
                @* ── Edit-Modus ── *@
                <div class="trip-edit-form">
                    <div class="input-wrap-split">
                        <input type="number" min="0" step="0.1" @bind="_editKm" placeholder="km" style="flex:1" />
                        <span class="input-suffix-small">km</span>
                        <input type="text" @bind="_editName" placeholder="Name" style="flex:2" />
                    </div>
                    <div class="input-wrap-split" style="margin-top:8px">
                        <input type="date" lang="de-DE" @bind="_editDate" style="flex:2" />
                        <input type="time" @bind="_editTime" style="flex:1" />
                    </div>
                    <div class="input-wrap-split" style="margin-top:8px">
                        <input type="number" min="0" max="100" @bind="_editBatt" placeholder="Akku %" style="flex:1" />
                        <span class="input-suffix-small">%</span>
                    </div>
                    <div class="btn-row" style="margin-top:10px">
                        <button class="btn secondary" style="padding:8px" @onclick="CancelEdit">Abbrechen</button>
                        <button class="btn" style="padding:8px" @onclick="() => SaveEdit(trip.Id)">Speichern ✓</button>
                    </div>
                </div>
            }
            else
            {
                @* ── Anzeigemodus ── *@
                <div class="trip-left">
                    <span class="trip-date">@trip.Date.ToString("dd.MM.yyyy HH:mm")</span>
                    <span class="trip-name">@(string.IsNullOrEmpty(trip.Name) ? "Fahrt" : trip.Name)</span>
                </div>
                <div class="trip-right">
                    <div class="trip-km">@trip.Km.ToString("F1") km</div>
                    @if (trip.BatteryUsedPercent.HasValue)
                    {
                        <div class="trip-used">−@trip.BatteryUsedPercent% Akku</div>
                    }
                </div>
                <button class="trip-edit" @onclick="() => StartEdit(trip)" title="Bearbeiten">✏️</button>
            }
            @if (_editId != trip.Id)
            {
                <button class="trip-del" @onclick="() => ConfirmDelete(trip.Id)" title="Löschen">🗑️</button>
            }
        </div>
    }
}

@code {
    private Toast? _toast;

    private readonly string[] _quickTags = ["Arbeit", "Einkaufen", "Spazierfahrt", "Sport", "Ausflug"];

    private double? _km;
    private string _name = "";
    private DateTime _date = DateTime.Today;
    private TimeOnly _time = TimeOnly.FromDateTime(DateTime.Now);
    private int? _battUsed;
    private bool _kmError;

    // Edit state
    private Guid? _editId;
    private Guid? _confirmDeleteId;
    private double? _editKm;
    private string _editName = "";
    private DateTime _editDate;
    private TimeOnly _editTime;
    private int? _editBatt;

    private async Task AddTrip()
    {
        _kmError = false;
        if (!_km.HasValue || _km <= 0) { _kmError = true; return; }

        State.AddTrip(new Trip
        {
            Km = _km.Value,
            Name = _name.Trim(),
            Date = _date.Date + _time.ToTimeSpan(),
            BatteryUsedPercent = _battUsed
        });

        await State.SaveTripsAsync();
        _km = null; _name = ""; _battUsed = null;
        _date = DateTime.Today; _time = TimeOnly.FromDateTime(DateTime.Now);
        _toast?.Show("Fahrt hinzugefügt! 🚴");
    }

    private void StartEdit(Trip trip)
    {
        _editId   = trip.Id;
        _editKm   = trip.Km;
        _editName = trip.Name;
        _editDate = trip.Date.Date;
        _editTime = TimeOnly.FromDateTime(trip.Date);
        _editBatt = trip.BatteryUsedPercent;
    }

    private void CancelEdit() => _editId = null;

    private async Task SaveEdit(Guid id)
    {
        var trip = State.Trips.FirstOrDefault(t => t.Id == id);
        if (trip == null || !_editKm.HasValue || _editKm <= 0) return;

        trip.Km                 = _editKm.Value;
        trip.Name               = _editName.Trim();
        trip.Date               = _editDate.Date + _editTime.ToTimeSpan();
        trip.BatteryUsedPercent = _editBatt;

        await State.SaveTripsAsync();
        _editId = null;
        _toast?.Show("Gespeichert ✓");
    }

    private void ConfirmDelete(Guid id) => _confirmDeleteId = id;
    private void CancelDelete() => _confirmDeleteId = null;

    private async Task ConfirmDeleteYes()
    {
        if (_confirmDeleteId.HasValue)
        {
            State.RemoveTrip(_confirmDeleteId.Value);
            await State.SaveTripsAsync();
            _confirmDeleteId = null;
        }
    }

    private async Task ClearAll()
    {
        State.ClearTrips();
        await State.SaveTripsAsync();
        _toast?.Show("Liste geleert.");
    }
}
