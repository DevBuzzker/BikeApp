@inherits LayoutComponentBase
@inject BikeStateService State
@inject NavigationManager Nav

<div class="shell">
    <header class="topbar">
        <span class="topbar-icon">⚡</span>
        <span class="topbar-title">E-Bike Tracker</span>
        <span class="topbar-right">
            <span class="topbar-time">@_now</span>
            <button class="topbar-reset-btn" @onclick="OpenReset" title="App zurücksetzen">↺</button>
        </span>
    </header>

    <main class="content">
        @Body
    </main>

    <nav class="bottom-nav">
        <NavLink class="nav-item" href="" Match="NavLinkMatch.All">
            <span class="nav-icon">🚴</span>
            <span class="nav-label">Fahrrad</span>
        </NavLink>
        <NavLink class="nav-item" href="kilometer">
            <span class="nav-icon">📍</span>
            <span class="nav-label">Kilometer</span>
        </NavLink>
        <NavLink class="nav-item" href="wartung">
            <span class="nav-icon">🔧</span>
            <span class="nav-label">Wartung</span>
        </NavLink>
    </nav>
</div>

@if (_showConfirm)
{
    <div class="modal-backdrop" @onclick="CloseReset">
        <div class="modal-box" @onclick:stopPropagation>
            <div class="modal-title">App zurücksetzen?</div>
            <div class="modal-body">Alle gespeicherten Daten werden unwiderruflich gelöscht.</div>
            <div class="modal-actions">
                <button class="btn-outline" @onclick="CloseReset">Nein</button>
                <button class="btn-danger" @onclick="DoReset">Ja, zurücksetzen</button>
            </div>
        </div>
    </div>
}

@code {
    private string _now = DateTime.Now.ToString("HH:mm");
    private System.Threading.Timer? _timer;
    private bool _showConfirm;

    protected override async Task OnInitializedAsync()
    {
        await State.LoadAsync();
        _timer = new System.Threading.Timer(_ =>
        {
            _now = DateTime.Now.ToString("HH:mm");
            InvokeAsync(StateHasChanged);
        }, null, TimeSpan.Zero, TimeSpan.FromSeconds(30));
    }

    private void OpenReset()  => _showConfirm = true;
    private void CloseReset() => _showConfirm = false;

    private async Task DoReset()
    {
        _showConfirm = false;
        await State.ResetAsync();
        Nav.NavigateTo("/kilometer", forceLoad: false);
        Nav.NavigateTo("/", forceLoad: false);
    }

    public void Dispose() => _timer?.Dispose();
}
